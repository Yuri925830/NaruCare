{
  "name": "narucare-agent",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"wrangler dev --config worker/wrangler.jsonc --port 8787\"",
    "dev:web": "vite",
    "dev:api": "wrangler dev --config worker/wrangler.jsonc --port 8787",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "visual:check": "node scripts/visual-check.mjs",
    "naru:extract": "python scripts/extract-naru-poses.py",
    "countries:generate": "node scripts/generate-countries.mjs",
    "locales:generate": "node scripts/generate-locales.mjs",
    "worker:types": "wrangler types --config worker/wrangler.jsonc worker/worker-configuration.d.ts",
    "worker:check": "wrangler deploy --config worker/wrangler.jsonc --dry-run --outdir .wrangler-dry-run",
    "db:local": "wrangler d1 migrations apply narucare --local --config worker/wrangler.jsonc",
    "db:remote": "wrangler d1 migrations apply narucare --remote --config worker/wrangler.jsonc"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "playwright-core": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "world-countries": "^5.1.0",
    "wrangler": "^4.112.0"
  }
}
